{
  "name": "@basalt/design-system",
  "version": "1.0.0",
  "description": "Basalt design system — tokens, components, and icons. Code-native, Git-backed, AI-ready.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": "./dist/tailwind.config.js",
    "./tokens": "./tokens"
  },
  "files": [
    "dist",
    "tokens",
    "components.json",
    "icons"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "prepublishOnly": "npm run build",
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "keywords": ["design-system", "tokens", "dtcg", "basalt"],
  "repository": {
    "type": "git",
    "url": "https://github.com/basalt-run/design-system"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "node-watch": "^0.7.4"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
