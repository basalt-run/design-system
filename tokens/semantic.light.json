{
  "$metadata": {
    "basalt": {
      "file": "semantic.light",
      "version": "0.1.0",
      "spec": "dtcg-2025.10",
      "requires": ["primitives"],
      "description": "Semantic aliases for light mode. All aliases resolve via {dot.notation} to primitives.json."
    }
  },

  "color": {
    "bg": {
      "$type": "color",
      "$description": "Surface backgrounds — from lowest to highest elevation.",
      "canvas":   { "$value": "{color.stone.100}", "$description": "App chrome, sidebar, outer frame" },
      "page":     { "$value": "{color.stone.50}",  "$description": "Main content area — the default surface" },
      "elevated": { "$value": "#FFFFFF",            "$description": "Cards, dialogs — lifted above page" },
      "overlay":  { "$value": "{color.stone.50}",  "$description": "Popovers, dropdowns, tooltips" },
      "inset":    { "$value": "{color.stone.200}",  "$description": "Input backgrounds, code blocks, sunken regions" },
      "inverse":  { "$value": "{color.stone.900}",  "$description": "Inverse surface — for tooltips with inverted treatment" }
    },

    "text": {
      "$type": "color",
      "primary":    { "$value": "{color.stone.900}", "$description": "Main readable text" },
      "secondary":  { "$value": "{color.stone.500}", "$description": "Supporting text, metadata, labels" },
      "tertiary":   { "$value": "{color.stone.400}", "$description": "Placeholder, hint text" },
      "disabled":   { "$value": "{color.stone.300}", "$description": "Non-interactive text" },
      "inverse":    { "$value": "{color.stone.50}",  "$description": "Text on dark/inverse surfaces" },
      "onAccent":   { "$value": "{color.stone.950}", "$description": "Text placed on ember accent backgrounds" },
      "link":       { "$value": "{color.ember.600}", "$description": "Hyperlinks in prose" },
      "linkHover":  { "$value": "{color.ember.700}" }
    },

    "border": {
      "$type": "color",
      "subtle":   { "$value": "{color.stone.200}", "$description": "Hairline dividers, table rows" },
      "default":  { "$value": "{color.stone.300}", "$description": "Input borders, card borders" },
      "strong":   { "$value": "{color.stone.400}", "$description": "Prominent borders, focused inputs" },
      "inverse":  { "$value": "{color.stone.600}" }
    },

    "accent": {
      "$type": "color",
      "subtle":   { "$value": "{color.ember.100}", "$description": "Accent tint backgrounds" },
      "muted":    { "$value": "{color.ember.200}" },
      "default":  { "$value": "{color.ember.500}", "$description": "Primary CTA, active states, highlights" },
      "hover":    { "$value": "{color.ember.600}", "$description": "Accent on hover" },
      "active":   { "$value": "{color.ember.700}", "$description": "Accent on press" },
      "focus":    { "$value": "{color.ember.500}", "$description": "Focus ring color" }
    },

    "feedback": {
      "$type": "color",
      "positive": {
        "subtle":   { "$value": "{color.positive.100}" },
        "default":  { "$value": "{color.positive.500}" },
        "strong":   { "$value": "{color.positive.700}" }
      },
      "warning": {
        "subtle":   { "$value": "{color.warning.100}" },
        "default":  { "$value": "{color.warning.500}" },
        "strong":   { "$value": "{color.warning.700}" }
      },
      "error": {
        "subtle":   { "$value": "{color.destructive.100}" },
        "default":  { "$value": "{color.destructive.500}" },
        "strong":   { "$value": "{color.destructive.700}" }
      }
    },

    "token": {
      "$type": "color",
      "$description": "UI chrome specific to token visualization — the core product UI.",
      "colorSwatch":  { "$value": "{color.stone.200}", "$description": "Empty color swatch background" },
      "aliasBadge":   { "$value": "{color.ember.100}", "$description": "Alias indicator chip background" },
      "aliasBadgeText": { "$value": "{color.ember.700}" },
      "missingRef":   { "$value": "{color.destructive.100}", "$description": "Broken alias highlight" },
      "missingRefText": { "$value": "{color.destructive.700}" },
      "deprecated":   { "$value": "{color.warning.100}" },
      "deprecatedText": { "$value": "{color.warning.700}" },
      "added":        { "$value": "{color.positive.100}", "$description": "Newly added token in diff view" },
      "addedText":    { "$value": "{color.positive.700}" },
      "modified":     { "$value": "{color.ember.100}", "$description": "Modified token in diff view" },
      "modifiedText": { "$value": "{color.ember.700}" }
    }
  },

  "shadow": {
    "$description": "Semantic shadow assignments by component role. Light mode only — see semantic.dark.json for dark mode elevation strategy.",
    "input":   { "$type": "shadow", "$value": "{shadow.xs}", "$description": "Subtle depth on form inputs" },
    "card":    { "$type": "shadow", "$value": "{shadow.md}", "$description": "Default card elevation" },
    "dialog":  { "$type": "shadow", "$value": "{shadow.xl}", "$description": "Modal dialogs, drawers" },
    "popover": { "$type": "shadow", "$value": "{shadow.lg}", "$description": "Dropdowns, popovers, command menus" },
    "focus":   {
      "$type": "shadow",
      "$value": {
        "offsetX": "0", "offsetY": "0",
        "blur": "0", "spread": "3px",
        "color": "{color.ember.500}"
      },
      "$description": "Keyboard focus ring — uses accent alias, not primitive"
    }
  },

  "typography": {
    "$description": "Semantic type roles — what components reference.",
    "body": {
      "fontFamily":    { "$value": "{typography.fontFamily.sans}" },
      "fontSize":      { "$value": "{typography.fontSize.base}" },
      "fontWeight":    { "$value": "{typography.fontWeight.regular}" },
      "lineHeight":    { "$value": "{typography.lineHeight.normal}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.normal}" }
    },
    "bodySmall": {
      "fontFamily":    { "$value": "{typography.fontFamily.sans}" },
      "fontSize":      { "$value": "{typography.fontSize.sm}" },
      "fontWeight":    { "$value": "{typography.fontWeight.regular}" },
      "lineHeight":    { "$value": "{typography.lineHeight.normal}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.normal}" }
    },
    "label": {
      "fontFamily":    { "$value": "{typography.fontFamily.sans}" },
      "fontSize":      { "$value": "{typography.fontSize.xs}" },
      "fontWeight":    { "$value": "{typography.fontWeight.medium}" },
      "lineHeight":    { "$value": "{typography.lineHeight.none}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.wide}" }
    },
    "heading1": {
      "fontFamily":    { "$value": "{typography.fontFamily.display}" },
      "fontSize":      { "$value": "{typography.fontSize.4xl}" },
      "fontWeight":    { "$value": "{typography.fontWeight.bold}" },
      "lineHeight":    { "$value": "{typography.lineHeight.tight}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.tighter}" }
    },
    "heading2": {
      "fontFamily":    { "$value": "{typography.fontFamily.display}" },
      "fontSize":      { "$value": "{typography.fontSize.2xl}" },
      "fontWeight":    { "$value": "{typography.fontWeight.semibold}" },
      "lineHeight":    { "$value": "{typography.lineHeight.tight}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.tighter}" }
    },
    "heading3": {
      "fontFamily":    { "$value": "{typography.fontFamily.display}" },
      "fontSize":      { "$value": "{typography.fontSize.xl}" },
      "fontWeight":    { "$value": "{typography.fontWeight.semibold}" },
      "lineHeight":    { "$value": "{typography.lineHeight.snug}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.normal}" }
    },
    "code": {
      "fontFamily":    { "$value": "{typography.fontFamily.mono}" },
      "fontSize":      { "$value": "{typography.fontSize.sm}" },
      "fontWeight":    { "$value": "{typography.fontWeight.regular}" },
      "lineHeight":    { "$value": "{typography.lineHeight.relaxed}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.normal}" }
    },
    "codeSmall": {
      "fontFamily":    { "$value": "{typography.fontFamily.mono}" },
      "fontSize":      { "$value": "{typography.fontSize.xs}" },
      "fontWeight":    { "$value": "{typography.fontWeight.regular}" },
      "lineHeight":    { "$value": "{typography.lineHeight.normal}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.normal}" }
    }
  },

  "spacing": {
    "$description": "Semantic spacing aliases — component-level intent.",
    "component": {
      "paddingXs": { "$type": "dimension", "$value": "{spacing.2}", "$description": "Tight padding — badges, chips" },
      "paddingSm": { "$type": "dimension", "$value": "{spacing.3}", "$description": "Small components — icon buttons" },
      "paddingMd": { "$type": "dimension", "$value": "{spacing.4}", "$description": "Default component padding — buttons, inputs" },
      "paddingLg": { "$type": "dimension", "$value": "{spacing.6}", "$description": "Large components — cards, panels" }
    },
    "layout": {
      "gapSm":    { "$type": "dimension", "$value": "{spacing.4}",  "$description": "Tight layout gaps" },
      "gapMd":    { "$type": "dimension", "$value": "{spacing.6}",  "$description": "Default section gap" },
      "gapLg":    { "$type": "dimension", "$value": "{spacing.12}", "$description": "Major section spacing" },
      "pagePad":  { "$type": "dimension", "$value": "{spacing.8}",  "$description": "Page-edge horizontal padding" }
    }
  },

  "radius": {
    "$description": "Semantic radius aliases by component type.",
    "button":  { "$type": "dimension", "$value": "{radius.md}", "$description": "Default button radius" },
    "input":   { "$type": "dimension", "$value": "{radius.md}" },
    "card":    { "$type": "dimension", "$value": "{radius.lg}" },
    "dialog":  { "$type": "dimension", "$value": "{radius.xl}" },
    "badge":   { "$type": "dimension", "$value": "{radius.full}", "$description": "Pill-shaped badges" },
    "swatch":  { "$type": "dimension", "$value": "{radius.sm}",   "$description": "Color token swatches" },
    "tooltip": { "$type": "dimension", "$value": "{radius.md}" }
  }
}
