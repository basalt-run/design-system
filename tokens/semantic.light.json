{
  "$metadata": {
    "basalt": {
      "file": "semantic.light",
      "version": "1.0.0",
      "spec": "dtcg-2025.10",
      "description": "Semantic alias tokens — light mode. Components consume these, never primitives.",
      "mode": "light",
      "requires": ["primitives"]
    }
  },

  "color": {
    "$type": "color",

    "background": {
      "$description": "Page and surface backgrounds.",
      "page":     { "$value": "{color.stone.50}",  "$description": "Default page background" },
      "surface":  { "$value": "{color.stone.100}", "$description": "Cards, panels, sidebars" },
      "elevated": { "$value": "{color.white}",     "$description": "Elevated surfaces — modals, dropdowns" },
      "sunken":   { "$value": "{color.stone.200}", "$description": "Recessed areas — code blocks, input backgrounds" },
      "overlay":  { "$value": "rgba(0, 0, 0, 0.4)", "$description": "Modal backdrop" },
      "inverse":  { "$value": "{color.stone.900}", "$description": "Inverse surface — tooltips, dark badges" }
    },

    "text": {
      "$description": "Text colors.",
      "primary":   { "$value": "{color.stone.900}", "$description": "Body text, headings" },
      "secondary": { "$value": "{color.stone.500}", "$description": "Supporting text, descriptions" },
      "tertiary":  { "$value": "{color.stone.400}", "$description": "Placeholder text, hints" },
      "disabled":  { "$value": "{color.stone.300}", "$description": "Disabled state text" },
      "inverse":   { "$value": "{color.stone.50}",  "$description": "Text on dark/inverse surfaces" },
      "onAccent":  { "$value": "{color.white}",     "$description": "Text on ember/accent backgrounds" },
      "link":      { "$value": "{color.ember.600}", "$description": "Interactive link text" },
      "linkHover": { "$value": "{color.ember.700}", "$description": "Link hover state" },
      "code":      { "$value": "{color.ember.700}", "$description": "Inline code text" }
    },

    "border": {
      "$description": "Border and divider colors.",
      "default":  { "$value": "{color.stone.200}", "$description": "Default border — cards, inputs, dividers" },
      "strong":   { "$value": "{color.stone.300}", "$description": "Stronger border — active inputs, focused" },
      "subtle":   { "$value": "{color.stone.100}", "$description": "Very subtle — nested sections" },
      "inverse":  { "$value": "{color.stone.700}", "$description": "Border on dark surfaces" },
      "focus":    { "$value": "{color.ember.500}", "$description": "Focus ring color — WCAG 2.4.11" },
      "accent":   { "$value": "{color.ember.500}", "$description": "Accent border — active nav item" }
    },

    "action": {
      "$description": "Primary interactive/CTA color.",
      "bg":          { "$value": "{color.ember.500}", "$description": "Primary button background" },
      "bgHover":     { "$value": "{color.ember.600}", "$description": "Primary button hover" },
      "bgActive":    { "$value": "{color.ember.700}", "$description": "Primary button pressed" },
      "bgDisabled":  { "$value": "{color.stone.200}", "$description": "Disabled button background" },
      "text":        { "$value": "{color.white}",     "$description": "Text on primary button" },
      "textDisabled":{ "$value": "{color.stone.400}", "$description": "Text on disabled button" },
      "subtle":      { "$value": "{color.ember.50}",  "$description": "Ghost/subtle action background" },
      "subtleHover": { "$value": "{color.ember.100}", "$description": "Ghost action hover" }
    },

    "neutral": {
      "$description": "Secondary interactive / ghost color.",
      "bg":          { "$value": "{color.white}",     "$description": "Secondary button background" },
      "bgHover":     { "$value": "{color.stone.100}", "$description": "Secondary button hover" },
      "bgActive":    { "$value": "{color.stone.200}", "$description": "Secondary button pressed" },
      "bgDisabled":  { "$value": "{color.stone.100}", "$description": "Disabled secondary background" },
      "text":        { "$value": "{color.stone.700}", "$description": "Secondary button text" },
      "textHover":   { "$value": "{color.stone.900}", "$description": "Secondary button text hover" },
      "border":      { "$value": "{color.stone.300}", "$description": "Secondary button border" },
      "borderHover": { "$value": "{color.stone.400}", "$description": "Secondary button border hover" }
    },

    "ghost": {
      "$description": "Minimal action — no background until interaction.",
      "bg":       { "$value": "{color.transparent}" },
      "bgHover":  { "$value": "{color.stone.100}" },
      "bgActive": { "$value": "{color.stone.200}" },
      "text":     { "$value": "{color.stone.600}" },
      "textHover":{ "$value": "{color.stone.900}" }
    },

    "danger": {
      "$description": "Destructive action color.",
      "bg":          { "$value": "{color.danger.500}", "$description": "Danger button background" },
      "bgHover":     { "$value": "{color.danger.600}", "$description": "Danger button hover" },
      "bgSubtle":    { "$value": "{color.danger.50}",  "$description": "Danger subtle/ghost background" },
      "bgSubtleHover":{ "$value": "{color.danger.100}" },
      "text":        { "$value": "{color.white}" },
      "textSubtle":  { "$value": "{color.danger.700}", "$description": "Danger text on light background" },
      "border":      { "$value": "{color.danger.300}" }
    },

    "status": {
      "$description": "Semantic feedback colors.",
      "positive": {
        "bg":     { "$value": "{color.positive.50}" },
        "border": { "$value": "{color.positive.200}" },
        "text":   { "$value": "{color.positive.700}" },
        "icon":   { "$value": "{color.positive.500}" }
      },
      "warning": {
        "bg":     { "$value": "{color.warning.50}" },
        "border": { "$value": "{color.warning.200}" },
        "text":   { "$value": "{color.warning.700}" },
        "icon":   { "$value": "{color.warning.500}" }
      },
      "danger": {
        "bg":     { "$value": "{color.danger.50}" },
        "border": { "$value": "{color.danger.200}" },
        "text":   { "$value": "{color.danger.700}" },
        "icon":   { "$value": "{color.danger.500}" }
      },
      "info": {
        "bg":     { "$value": "{color.stone.100}" },
        "border": { "$value": "{color.stone.200}" },
        "text":   { "$value": "{color.stone.700}" },
        "icon":   { "$value": "{color.stone.500}" }
      }
    },

    "brand": {
      "$description": "Direct brand color references — use sparingly.",
      "primary":   { "$value": "{color.ember.500}" },
      "secondary": { "$value": "{color.stone.900}" },
      "muted":     { "$value": "{color.ember.100}" }
    }
  },

  "elevation": {
    "$description": "Light mode uses shadows for elevation.",
    "1": { "$value": "{shadow.xs}", "$description": "Subtle — inline raised elements" },
    "2": { "$value": "{shadow.sm}", "$description": "Buttons, inputs" },
    "3": { "$value": "{shadow.md}", "$description": "Cards, dropdowns" },
    "4": { "$value": "{shadow.lg}", "$description": "Dialogs, floating panels" }
  }
}
