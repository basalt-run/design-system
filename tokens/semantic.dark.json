{
  "$metadata": {
    "basalt": {
      "file": "semantic.dark",
      "version": "1.0.0",
      "spec": "dtcg-2025.10",
      "description": "Semantic alias tokens — dark mode. Same structure as semantic.light, different primitive references.",
      "mode": "dark",
      "requires": ["primitives"]
    }
  },

  "color": {
    "$type": "color",

    "background": {
      "$description": "Page and surface backgrounds.",
      "page":     { "$value": "{color.stone.950}", "$description": "Default page background" },
      "surface":  { "$value": "{color.stone.900}", "$description": "Cards, panels, sidebars" },
      "elevated": { "$value": "{color.stone.800}", "$description": "Elevated surfaces — dropdowns, popovers" },
      "sunken":   { "$value": "rgba(0, 0, 0, 0.3)", "$description": "Recessed areas — code blocks, input backgrounds" },
      "overlay":  { "$value": "rgba(0, 0, 0, 0.6)", "$description": "Modal backdrop" },
      "inverse":  { "$value": "{color.stone.100}", "$description": "Inverse surface — light tooltips" }
    },

    "text": {
      "$description": "Text colors.",
      "primary":   { "$value": "{color.stone.50}",  "$description": "Body text, headings" },
      "secondary": { "$value": "{color.stone.400}", "$description": "Supporting text, descriptions" },
      "tertiary":  { "$value": "{color.stone.600}", "$description": "Placeholder text, hints" },
      "disabled":  { "$value": "{color.stone.700}", "$description": "Disabled state text" },
      "inverse":   { "$value": "{color.stone.900}", "$description": "Text on light/inverse surfaces" },
      "onAccent":  { "$value": "{color.white}",     "$description": "Text on ember/accent backgrounds" },
      "link":      { "$value": "{color.ember.400}", "$description": "Interactive link text" },
      "linkHover": { "$value": "{color.ember.300}", "$description": "Link hover state" },
      "code":      { "$value": "{color.ember.400}", "$description": "Inline code text" }
    },

    "border": {
      "$description": "Border and divider colors.",
      "default":  { "$value": "{color.stone.800}", "$description": "Default border — cards, inputs, dividers" },
      "strong":   { "$value": "{color.stone.700}", "$description": "Stronger border — active inputs" },
      "subtle":   { "$value": "{color.stone.900}", "$description": "Very subtle border — nested sections" },
      "inverse":  { "$value": "{color.stone.200}", "$description": "Border on light surfaces" },
      "focus":    { "$value": "{color.ember.500}", "$description": "Focus ring color — WCAG 2.4.11" },
      "accent":   { "$value": "{color.ember.500}", "$description": "Accent border — active nav item" }
    },

    "action": {
      "$description": "Primary interactive/CTA color.",
      "bg":           { "$value": "{color.ember.500}", "$description": "Primary button background" },
      "bgHover":      { "$value": "{color.ember.600}", "$description": "Primary button hover" },
      "bgActive":     { "$value": "{color.ember.700}", "$description": "Primary button pressed" },
      "bgDisabled":   { "$value": "{color.stone.800}", "$description": "Disabled button background" },
      "text":         { "$value": "{color.white}",     "$description": "Text on primary button" },
      "textDisabled": { "$value": "{color.stone.600}", "$description": "Text on disabled button" },
      "subtle":       { "$value": "rgba(249, 115, 22, 0.1)",  "$description": "Ghost/subtle action background" },
      "subtleHover":  { "$value": "rgba(249, 115, 22, 0.15)", "$description": "Ghost action hover" }
    },

    "neutral": {
      "$description": "Secondary interactive / ghost color.",
      "bg":          { "$value": "{color.stone.800}",  "$description": "Secondary button background" },
      "bgHover":     { "$value": "{color.stone.700}",  "$description": "Secondary button hover" },
      "bgActive":    { "$value": "{color.stone.600}",  "$description": "Secondary button pressed" },
      "bgDisabled":  { "$value": "{color.stone.900}",  "$description": "Disabled secondary background" },
      "text":        { "$value": "{color.stone.300}",  "$description": "Secondary button text" },
      "textHover":   { "$value": "{color.stone.100}",  "$description": "Secondary button text hover" },
      "border":      { "$value": "{color.stone.700}",  "$description": "Secondary button border" },
      "borderHover": { "$value": "{color.stone.500}",  "$description": "Secondary button border hover" }
    },

    "ghost": {
      "$description": "Minimal action — no background until interaction.",
      "bg":        { "$value": "{color.transparent}" },
      "bgHover":   { "$value": "{color.stone.800}" },
      "bgActive":  { "$value": "{color.stone.700}" },
      "text":      { "$value": "{color.stone.400}" },
      "textHover": { "$value": "{color.stone.100}" }
    },

    "danger": {
      "$description": "Destructive action color.",
      "bg":              { "$value": "{color.danger.500}" },
      "bgHover":         { "$value": "{color.danger.600}" },
      "bgSubtle":        { "$value": "rgba(239, 68, 68, 0.1)" },
      "bgSubtleHover":   { "$value": "rgba(239, 68, 68, 0.15)" },
      "text":            { "$value": "{color.white}" },
      "textSubtle":      { "$value": "{color.danger.400}" },
      "border":          { "$value": "{color.danger.700}" }
    },

    "status": {
      "$description": "Semantic feedback colors.",
      "positive": {
        "bg":     { "$value": "rgba(34, 197, 94, 0.1)" },
        "border": { "$value": "rgba(34, 197, 94, 0.2)" },
        "text":   { "$value": "{color.positive.400}" },
        "icon":   { "$value": "{color.positive.500}" }
      },
      "warning": {
        "bg":     { "$value": "rgba(234, 179, 8, 0.1)" },
        "border": { "$value": "rgba(234, 179, 8, 0.2)" },
        "text":   { "$value": "{color.warning.400}" },
        "icon":   { "$value": "{color.warning.500}" }
      },
      "danger": {
        "bg":     { "$value": "rgba(239, 68, 68, 0.1)" },
        "border": { "$value": "rgba(239, 68, 68, 0.2)" },
        "text":   { "$value": "{color.danger.400}" },
        "icon":   { "$value": "{color.danger.500}" }
      },
      "info": {
        "bg":     { "$value": "{color.stone.800}" },
        "border": { "$value": "{color.stone.700}" },
        "text":   { "$value": "{color.stone.300}" },
        "icon":   { "$value": "{color.stone.400}" }
      }
    },

    "brand": {
      "$description": "Direct brand color references — use sparingly.",
      "primary":   { "$value": "{color.ember.500}" },
      "secondary": { "$value": "{color.stone.100}" },
      "muted":     { "$value": "rgba(249, 115, 22, 0.1)" }
    }
  },

  "elevation": {
    "$description": "Dark mode uses borders for elevation, not shadows.",
    "1": { "$value": "{color.stone.800}", "$description": "Subtle raised border" },
    "2": { "$value": "{color.stone.700}", "$description": "Card, input border" },
    "3": { "$value": "{color.stone.600}", "$description": "Dropdown, active element border" },
    "4": { "$value": "{color.stone.500}", "$description": "Modal, prominent border" }
  }
}
